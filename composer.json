{
    "name": "geoffreyrose/us-holidays",
    "description": "US Holidays Wrapper for the Carbon DateTime Library.",
    "keywords": ["Bank Holiday", "Holiday", "Holidays", "Carbon", "US Holiday", "US Holidays"],
    "license": "MIT",
    "require": {
        "nesbot/carbon": "^3.0",
        "php": "^8.1",
        "ext-calendar": "*"
    },
    "autoload": {
        "psr-4": {
            "USHolidays\\": "src/USHolidays"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "Tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10|^11|^12|^13",
        "php-coveralls/php-coveralls": "^2.9.1",
        "laravel/pint": "^1.29"
    },
    "extra": {
        "laravel": {
            "providers": [
                "USHolidays\\ServiceProvider"
            ],
            "aliases": {
                "USHolidays": "USHolidays\\Facades\\USHolidays"
            }
        }
    }
}
